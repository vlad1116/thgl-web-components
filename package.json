{
  "name": "the-hidden-gaming-lair",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "clean:all": "rimraf **/node_modules **/.next **/dist **/.turbo && bun install",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter='*-web'",
    "dev:overwolf": "turbo run dev --filter='*-overwolf'",
    "dev:core": "turbo run dev --filter='thgl-*'",
    "dev:avowed": "turbo run dev --filter='avowed-*'",
    "dev:chrono-odyssey": "turbo run dev --filter='chrono-odyssey-*'",
    "dev:diablo4": "turbo run dev --filter='diablo4-*'",
    "dev:dune-awakening": "turbo run dev --filter='dune-awakening-*'",
    "dev:grounded2": "turbo run dev --filter='grounded2-*'",
    "dev:hogwarts-legacy": "turbo run dev --filter='hogwarts-legacy-*'",
    "dev:infinity-nikki": "turbo run dev --filter='infinity-nikki-*'",
    "dev:night-crows": "turbo run dev --filter='night-crows-*'",
    "dev:once-human": "turbo run dev --filter='once-human-*'",
    "dev:palia": "turbo run dev --filter='palia-*'",
    "dev:palworld": "turbo run dev --filter='palworld-*'",
    "dev:pax-dei": "turbo run dev --filter='pax-dei-*'",
    "dev:rsdragonwilds": "turbo run dev --filter='rsdragonwilds-*'",
    "dev:satisfactory": "turbo run dev --filter='satisfactory-*'",
    "dev:soulframe": "turbo run dev --filter='soulframe-*'",
    "dev:wuthering-waves": "turbo run dev --filter='wuthering-waves-*'",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "update-deps": "bunx npm-check-updates -u -ws --root"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "turbo": "2.9.16"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0"
  },
  "overrides": {
    "embla-carousel": "8.6.0",
    "embla-carousel-reactive-utils": "8.6.0"
  },
  "catalog": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "next": "16.2.6",
    "typescript": "6.0.3",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/node": "25.9.1",
    "vite": "8.0.16",
    "@vitejs/plugin-react-swc": "4.3.1",
    "tailwindcss": "4.3.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tailwindcss/cli": "4.3.0",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "tailwindcss-animate": "1.0.7",
    "@overwolf/types": "3.24.11",
    "@overwolf/ow-cli": "0.1.4",
    "eslint": "10.4.1",
    "@next/eslint-plugin-next": "16.2.6",
    "eslint-config-turbo": "2.9.16",
    "zustand": "5.0.14",
    "fuse.js": "7.4.0",
    "peerjs": "1.5.5",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "reflect-metadata": "0.2.2",
    "jsonwebtoken": "9.0.3",
    "@types/jsonwebtoken": "9.0.10"
  }
}
