    "./data": {
      "import": "./src/components/(data)/index.tsx"
    },
    "./full-map-dynamic": {
      "import": "./src/components/(dynamic)/full-map-dynamic.tsx"
    },
    "./header": {
      "import": "./src/components/(header)/index.tsx"
    },
    "./interactive-map": {
      "import": "./src/components/(interactive-map)/index.tsx"
    },
    "./markers-search": {
