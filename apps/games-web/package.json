{
  "name": "games-web",
  "version": "0.0.0",
  "private": true,
  "browserslist": [
    "chrome >= 91",
    "edge >= 91",
    "firefox >= 90",
    "safari >= 15",
    "and_chr >= 91",
    "and_ff >= 90",
    "ios_saf >= 15"
  ],
  "scripts": {
    "build": "next build",
    "clean": "rimraf .next node_modules",
    "dev": "next dev -p 3100 --turbopack",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "start": "next start -p 3100"
  },
  "dependencies": {
    "@repo/lib": "workspace:*",
    "@repo/ui": "workspace:*",
    "@vercel/blob": "1.0.0",
    "@vercel/kv": "catalog:",
    "@vercel/postgres": "0.10.0",
    "fuse.js": "catalog:",
    "jsonwebtoken": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "remark-gfm": "catalog:"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "postcss": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
